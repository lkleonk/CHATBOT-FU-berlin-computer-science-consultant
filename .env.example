# Docker Compose publishes application ports only on this host address. Keep
# loopback when Nginx/Caddy runs on the same server.
COMPOSE_BIND_ADDRESS=127.0.0.1
# Host port for the optional local static-frontend preview profile.
FRONTEND_PORT=3000

# Optional production Caddy profile. Set the public DNS names without a scheme,
# then start Compose with `--profile production`. APP_WWW_DOMAIN redirects to
# APP_DOMAIN and must be covered by DNS when the production profile is used.
APP_DOMAIN=localhost
APP_WWW_DOMAIN=www.localhost
CADDY_IMAGE=caddy:2-alpine
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Backend container
CONSULTANT_HOST=0.0.0.0
CONSULTANT_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Uvicorn trusts forwarded client-IP headers only from these proxy addresses.
# Keep 127.0.0.1 for direct local use. See README for the loopback-published
# Docker + reverse-proxy production setting.
FORWARDED_ALLOW_IPS=127.0.0.1

# Next.js public values are embedded in the static frontend export created by
# `frontend/npm run build`; rebuild and redeploy `frontend/out` after changing them.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false

# Pick exactly one LLM provider:
#   academiccloud  -> hosted AcademicCloud API
#   fu_ollama      -> FU Ollama on cuda01 via SSH tunnel (auto)
#   local_ollama   -> Ollama running on your host machine
LLM_PROVIDER=academiccloud

# Process-local daily quotas, both counted in user actions (one chat message or
# transcript upload). Counters reset at 00:00 UTC and on backend restart.
# DAILY_GLOBAL_ACTIONS is shared by everyone; DAILY_USER_ACTIONS applies per client IP.
# The old DAILY_LLM_INVOCATIONS name still works but counted individual LLM calls,
# of which one action makes roughly three -- re-pick the value rather than carry it over.
DAILY_GLOBAL_ACTIONS=150
DAILY_USER_ACTIONS=60

# Process-local session cleanup. Sessions expire after 48 hours of inactivity;
# cleanup scans run opportunistically during API activity.
SESSION_INACTIVITY_TTL_SECONDS=172800
SESSION_CLEANUP_INTERVAL_SECONDS=300

# --- AcademicCloud (read when LLM_PROVIDER=academiccloud) ---
ACADEMICCLOUD_BASE_URL=https://chat-ai.academiccloud.de/v1
ACADEMICCLOUD_MODEL=qwen3-235b-a22b
ACADEMICCLOUD_TEMPERATURE=0.2
ACADEMICCLOUD_MAX_TOKENS=1200
ACADEMICCLOUD_TIMEOUT=120
# ACADEMICCLOUD_API_KEY belongs in .env.local

# --- FU Ollama (read when LLM_PROVIDER=fu_ollama) ---
# SSH tunnel to cuda01 is opened automatically; no extra flag needed.
FU_OLLAMA_MODEL=llama3.2
FU_OLLAMA_TEMPERATURE=0.2
FU_OLLAMA_MAX_TOKENS=4096
FU_OLLAMA_TIMEOUT=120
FU_SSH_HOST=cuda01.imp.fu-berlin.de
FU_SSH_PORT=22
FU_REMOTE_BIND_ADDRESS=127.0.0.1
FU_REMOTE_BIND_PORT=11434
# FU_SSH_USER and FU_SSH_PASSWORD belong in .env.local

# --- Local Ollama (read when LLM_PROVIDER=local_ollama) ---
# Default host.docker.internal works for Docker Desktop on Windows/macOS.
LOCAL_OLLAMA_HOST=http://host.docker.internal:11434
LOCAL_OLLAMA_MODEL=llama3.2
LOCAL_OLLAMA_TEMPERATURE=0.2
LOCAL_OLLAMA_MAX_TOKENS=1200
LOCAL_OLLAMA_TIMEOUT=120

# Agent flow behavior
AGENT_SCOPE_CLASSIFIER_HISTORY_TURNS=1
AGENT_COURSE_SELECTOR_HISTORY_TURNS=2
AGENT_COURSE_SELECTOR_MAX_KEYS=20
AGENT_COURSE_SELECTOR_INCLUDE_SEMESTERS_NOTE=true
AGENT_ANSWER_COMPOSER_HISTORY_TURNS=4

# Local WizardFlow JSONL traces. Inputs include unredacted prompts, chat
# messages, and text extracted from uploaded transcripts. Set false on a
# production deployment that promises session-only temporary storage.
WIZARDFLOW_ENABLED=true
WIZARDFLOW_OUTPUT_DIR=traces
WIZARDFLOW_FILE_PREFIX=fu_cs_consultant
